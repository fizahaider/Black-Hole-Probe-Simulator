SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: use either DATABASE_URL or DB_* variables
DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_HOST=db
# DB_NAME=studymate
# DB_USER=studymate_user
# DB_PASSWORD=change-me
# DB_PORT=5432

# Optional compose postgres variables (local dev)
POSTGRES_DB=studymate
POSTGRES_USER=studymate_user
POSTGRES_PASSWORD=change-me

# Redis
REDIS_URL=redis://redis:6379/1

# Email settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=your-email@example.com
CONTACT_NOTIFICATION_EMAIL=alerts@example.com

# App/service keys
GROQ_API_KEY=replace-with-groq-api-key
GOOGLE_GENAI_API_KEY=replace-with-google-genai-api-key
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM
DEEPGRAM_API_KEY=replace-with-deepgram-api-key

# Frontend integration
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
